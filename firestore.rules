rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles. Readable by any signed-in user so people can be found by
    // email to call them. Each user can only write their own profile.
    // (If you'd rather not expose profiles to lookup, replace the read rule
    //  with a Cloud Function that resolves email -> uid server-side.)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      // Each user's private recent-contacts list.
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Call signaling documents. Only the two participants can read/update them.
    match /calls/{callId} {
      allow create: if request.auth != null
                    && request.resource.data.callerUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
                    && (resource.data.callerUid == request.auth.uid
                        || resource.data.calleeUid == request.auth.uid);

      // ICE candidate exchange — limited to signed-in users.
      match /{sub}/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
